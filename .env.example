# Configure the service with SANCHR__-prefixed environment variables.
# Double underscores (__) act as hierarchy separators.
# This public repo does not ship default config files; operators can use env vars
# directly or add their own optional config/*.yaml files outside version control.

SANCHR__DATABASE__POSTGRES__URL=postgres://sanchr:sanchr_dev@localhost:5432/sanchr
SANCHR__DATABASE__REDIS__URL=redis://localhost:6379
SANCHR__AUTH__JWT_SECRET=replace-me-with-a-unique-jwt-secret
SANCHR__AUTH__OTP_SECRET=replace-me-with-a-unique-otp-secret
SANCHR__CALLING__TURN_SECRET=replace-me-with-a-unique-turn-secret

# Local-only opt-in. Never enable outside an isolated development environment.
# SANCHR__AUTH__DEV_MODE=true

# Optional – uncomment to override ports
# SANCHR__SERVER__HTTP_PORT=8080
# SANCHR__SERVER__GRPC_PORT=9090
